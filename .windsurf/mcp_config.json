{
  "mcpServers": {
    "mcp-mariadb": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-v",
        "${workspaceFolder}/example-config.yaml:/app/config.yaml",
        "--network",
        "mcp-net",
        "-e",
        "MCP_MARIADB_CONFIG=/app/config.yaml",
        "siakhooi/mcp-mariadb:latest"
      ]
    }
  }
}
